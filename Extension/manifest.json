{
  "manifest_version": 3,
  "name": "Clickbait Crab",
  "version": "0.1.0",
  "description": "Deflates dramatic YouTube titles into calmer, clearer versions.",
  "permissions": ["storage"],
  "host_permissions": ["https://www.youtube.com/*"],
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Clickbait Crab",
    "default_popup": "popup.html"
  }
}
